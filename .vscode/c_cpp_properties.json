{
    "configurations": [
        {
            "name": "STM32F411RE Bare-Metal",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "STM32F411xE"
            ],
            "compilerPath": "arm-none-eabi-gcc",
            // Flags khớp với Makefile — Cortex-M4 + FPU hard-float
            "compilerArgs": [
                "-mcpu=cortex-m4",
                "-mthumb",
                "-mfloat-abi=hard",
                "-mfpu=fpv4-sp-d16"
            ],
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-arm"
        }
    ],
    "version": 4
}
